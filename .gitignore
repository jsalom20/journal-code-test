npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files
.env*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Coverage
coverage/

# Local databases
*.db
*.db-shm
*.db-wal

