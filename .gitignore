project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Rider
.idea/

# --- Next.js ---
node_modules/
.next/
out/
build/

# Misc
.DS_Store
*.pem

